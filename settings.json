{
    "charmed-icons.associations.languages": {
        "jupyter": "storybook"
    },
    "charmed-icons.associations.extensions": {
        "ipynb": "storybook",
        "unf": "fortran",
        "cmake": "makefile"
    },
    "charmed-icons.associations.files": {
        "pyproject.toml": "config",
        "kpaper.toml": "config",
        "input": "config",
        "config": "config",
        "out": "text"
    },
    "charmed-icons.associations.folders": {
        "notes": "folder_storybook",
        "notebooks": "folder_storybook",
        "LaTeX": "folder_fonts",
        "latex": "folder_fonts",
        "tex": "folder_fonts",
        "sims": "folder_model",
        "input": "folder_config",
        "Output": "folder_database",
        ".venv": "python",
        "log": "folder_docs",
        "logs": "folder_docs",
        "frames": "folder_image",
        "fortran": "fortran",
        "stats": "folder_function",
        "submit_scripts": "folder_script"
    },
    "chat.disableAIFeatures": true,
    "chat.agent.thinking.terminalTools": false,
    "chat.tools.terminal.enableAutoApprove": false,
    "editor.fontFamily": "Victor Mono",
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.showFoldingControls": "always",
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 101,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "name": "One Dark italic",
                "scope": [
                    "comment",
                    "entity.other.attribute-name",
                    "keyword",
                    "markup.underline.link",
                    "storage.modifier",
                    "storage.type",
                    "string.url",
                    "variable.language.super",
                    "variable.language.this"
                ],
                "settings": {
                    "fontStyle": "italic"
                }
            },
            {
                "name": "One Dark italic reset",
                "scope": [
                    "keyword.operator",
                    "keyword.other.type",
                    "storage.modifier.import",
                    "storage.modifier.package",
                    "storage.type.built-in",
                    "storage.type.function.arrow",
                    "storage.type.generic",
                    "storage.type.java",
                    "storage.type.primitive"
                ],
                "settings": {
                    "fontStyle": ""
                }
            }
        ]
    },
    "emmet.useInlineCompletions": true,
    "emmet.optimizeStylesheetParsing": false,
    "emmet.triggerExpansionOnTab": true,
    "emmet.showSuggestionsAsSnippets": true,
    "explorer.confirmDelete": false,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "files.autoSave": "onFocusChange",
    "files.autoGuessEncoding": true,
    "git.openRepositoryInParentFolders": "never",
    "jupyter.askForKernelRestart": false,
    "jupyter.kernels.trusted": [
        "/Users/keyan/.venv/bin/python3.14"
    ],
    "notebook.output.scrolling": true,
    "notebook.output.wordWrap": true,
    "remote.SSH.configFile": "~/.ssh/config",
    "remote.autoForwardPortsSource": "hybrid",
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontLigatures.enabled": true,
    "terminal.external.linuxExec": "bash",
    "terminal.integrated.initialHint": false,
    "terminal.integrated.defaultProfile.osx": "bash",
    "terminal.integrated.profiles.osx": {
        "bash": {
            "path": "/bin/bash",
            "args": [
                "-l"
            ]
        },
        "zsh": {
            "path": "zsh",
            "args": [
                "-l"
            ]
        },
        "fish": {
            "path": "fish",
            "args": [
                "-l"
            ]
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        },
        "pwsh": {
            "path": "pwsh",
            "icon": "terminal-powershell"
        }
    },
    "workbench.colorTheme": "Andromeda Night Operator",
    "workbench.productIconTheme": "material-product-icons",
    "workbench.iconTheme": "charmed-warm",
    "workbench.colorCustomizations": {
        //if this isn't dark enough error 
        // messages with white text are unreadable
        "terminal.ansiYellow": "#756100" 
    },
    "workbench.startupEditor": "none",
    "workbench.panel.showLabels": false,
    "workbench.editor.empty.hint": "hidden",
    "window.confirmSaveUntitledWorkspace": false,
}